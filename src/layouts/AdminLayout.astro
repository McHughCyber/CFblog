---
interface Props {
  title: string;
}

const { title } = Astro.props;
const accessUser = Astro.locals.accessUser;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";

function navClass(href: string): string {
  if (href === "/admin") {
    return pathname === "/admin" ? "active" : "";
  }
  return pathname === href || pathname.startsWith(`${href}/`) ? "active" : "";
}

const navItems = [
  { label: "Dashboard", href: "/admin" },
  { label: "Posts", href: "/admin/posts" },
  { label: "Categories", href: "/admin/categories" },
  { label: "Menus", href: "/admin/menus" },
  { label: "Redirects", href: "/admin/redirects" },
  { label: "Media", href: "/admin/media" },
  { label: "Theme", href: "/admin/theme" },
  { label: "Updates", href: "/admin/update" },
  { label: "Settings", href: "/admin/settings" }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} | CFblog Admin</title>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar" aria-label="Admin navigation">
        <a class="brand" href="/admin">CFblog</a>
        <nav>
          {navItems.map((item) => (
            <a class:list={["nav-link", navClass(item.href)]} href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <div class="workspace">
        <header class="topbar">
          <div>
            <p>Admin</p>
            <h1>{title}</h1>
          </div>
          <p class="identity">
            {accessUser?.email ?? "Cloudflare Access user"}
          </p>
        </header>

        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f4f1ea;
    color: #1f2523;
  }

  body {
    margin: 0;
  }

  .admin-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
  }

  .sidebar {
    border-right: 1px solid #d8d2c7;
    padding: 24px 18px;
    background: #ebe6dc;
  }

  .brand {
    display: inline-block;
    margin-bottom: 32px;
    color: #1f2523;
    font-size: 1.1rem;
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: grid;
    gap: 4px;
  }

  .nav-link {
    border: 1px solid transparent;
    padding: 9px 10px;
    color: #465148;
    font-size: 0.94rem;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link.active {
    border-color: #cfc7b8;
    background: #f7f4ee;
    color: #1f2523;
  }

  .workspace {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .topbar {
    min-height: 88px;
    border-bottom: 1px solid #d8d2c7;
    padding: 18px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: #f7f4ee;
  }

  .topbar p,
  .topbar h1 {
    margin: 0;
  }

  .topbar p {
    color: #6d746e;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .topbar h1 {
    margin-top: 4px;
    font-size: 1.42rem;
    line-height: 1.2;
  }

  .identity {
    max-width: 260px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: right;
  }

  main {
    padding: 28px;
  }

  @media (max-width: 820px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      border-right: 0;
      border-bottom: 1px solid #d8d2c7;
    }

    nav {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .identity {
      max-width: 100%;
      text-align: left;
    }

    main {
      padding: 20px;
    }
  }
</style>
