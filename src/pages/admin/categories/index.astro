---
import { env } from "cloudflare:workers";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import EmptyState from "../../../components/admin/EmptyState.astro";
import CategoryTree from "../../../components/admin/CategoryTree.astro";
import { buildCategoryTree } from "../../../lib/categories/build-tree";
import { listCategories } from "../../../lib/db/categories";

interface RuntimeEnv {
  CFBLOG_DB: D1Database;
}

const runtimeEnv = env as RuntimeEnv;
const flat = await listCategories(runtimeEnv.CFBLOG_DB);
const tree = buildCategoryTree(flat);
---

<AdminLayout title="Categories">
  <div class="page-head">
    <a class="new-cat" href="/admin/categories/new">New category</a>
  </div>

  {
    tree.length === 0 ? (
      <EmptyState
        title="No categories yet"
        detail="Create a root category, then add children for nested URLs."
      />
    ) : (
      <CategoryTree nodes={tree} />
    )
  }
</AdminLayout>

<style>
  .page-head {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 18px;
  }

  .new-cat {
    display: inline-block;
    padding: 9px 16px;
    border-radius: 6px;
    background: #2f6f4e;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }

  .new-cat:hover {
    background: #285f43;
  }
</style>
