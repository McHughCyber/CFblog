---
import { env } from "cloudflare:workers";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import ConfirmBar from "../../../components/admin/ConfirmBar.astro";
import FormField from "../../../components/admin/FormField.astro";
import { loadAiTrafficSettings } from "../../../lib/ai-traffic/load";
import type { AiTrafficSettings } from "../../../lib/ai-traffic/schema";
import { getSetting } from "../../../lib/db/settings";
import { loadIntegrationsSettings } from "../../../lib/integrations/load";
import {
  ADSENSE_PLACEMENT_KEYS,
  type AdSensePlacementKey,
  type IntegrationsSettings
} from "../../../lib/integrations/schema";

interface RuntimeEnv {
  CFBLOG_DB: D1Database;
}

interface SiteSettings {
  title: string;
  description: string;
  authorName?: string | null;
  defaultOgImageAssetId?: string | null;
}

const runtimeEnv = env as RuntimeEnv;
const [site, aiTraffic, integrations] = await Promise.all([
  getSetting<SiteSettings>(runtimeEnv.CFBLOG_DB, "site"),
  loadAiTrafficSettings(runtimeEnv.CFBLOG_DB),
  loadIntegrationsSettings(runtimeEnv.CFBLOG_DB)
]);

const initialAiTraffic: AiTrafficSettings = aiTraffic;
const initialIntegrations: IntegrationsSettings = integrations;
const placementLabels: Record<AdSensePlacementKey, string> = {
  postTop: "Post top",
  postAfterContent: "Post after content",
  homepageAfterFirstPost: "Homepage after first post",
  categoryAfterFirstPost: "Category after first post",
  siteFooter: "Site footer"
};
---

<AdminLayout title="Settings">
  <div class="settings-grid">
    <form class="panel">
      <ConfirmBar message="Core site settings are shown in read-only mode." />
      <FormField
        for="site-title"
        label="Site title"
        hint="This value is stored in D1 settings."
      >
        <input id="site-title" name="site-title" type="text" value={site?.title ?? "CFblog"} disabled />
      </FormField>
      <FormField
        for="site-description"
        label="Site description"
        hint="Used by public metadata, RSS, and homepage copy."
      >
        <textarea id="site-description" name="site-description" disabled>{site?.description ?? "A Cloudflare-native Astro blog."}</textarea>
      </FormField>
      <FormField
        for="site-author"
        label="Default author"
        hint="Used by homepage structured data when configured."
      >
        <input id="site-author" name="site-author" type="text" value={site?.authorName ?? "CFblog"} disabled />
      </FormField>
      <FormField
        for="site-og"
        label="Default Open Graph image asset ID"
        hint="Used as the fallback social image when a post has no OG image asset."
      >
        <input id="site-og" name="site-og" type="text" value={site?.defaultOgImageAssetId ?? ""} disabled />
      </FormField>
    </form>

    <form class="panel" id="ai-traffic-form">
      <ConfirmBar message="AI crawler controls here generate public hint files. Cloudflare enforcement and Pay Per Crawl are configured in the Cloudflare dashboard." />
      <FormField
        for="ai-description"
        label="AI-facing site description"
        hint="Published in llms.txt and crawlers.json."
      >
        <textarea id="ai-description" name="siteDescription">{initialAiTraffic.siteDescription}</textarea>
      </FormField>

      <FormField
        for="robots-policy"
        label="Robots policy"
        hint="Use robots.txt for crawler guidance; use Cloudflare AI Crawl Control for enforcement."
      >
        <select id="robots-policy" name="robotsPolicy">
          <option value="allow" selected={initialAiTraffic.robotsPolicy === "allow"}>Allow all crawlers</option>
          <option value="disallow-ai" selected={initialAiTraffic.robotsPolicy === "disallow-ai"}>
            Disallow listed AI crawlers
          </option>
        </select>
      </FormField>

      <FormField
        for="ai-user-agents"
        label="AI crawler user agents"
        hint="One user agent per line, used only when AI crawlers are disallowed."
      >
        <textarea id="ai-user-agents" name="aiUserAgents" class="mono-input">{initialAiTraffic.aiUserAgents.join("\n")}</textarea>
      </FormField>

      <div class="toggle-grid">
        <label><input id="llms-txt-enabled" type="checkbox" checked={initialAiTraffic.llmsTxtEnabled} /> llms.txt</label>
        <label><input id="llms-full-enabled" type="checkbox" checked={initialAiTraffic.llmsFullTxtEnabled} /> llms-full.txt</label>
        <label><input id="crawlers-json-enabled" type="checkbox" checked={initialAiTraffic.crawlersJsonEnabled} /> crawlers.json</label>
      </div>

      <FormField
        for="contact-url"
        label="Contact URL"
        hint="Optional absolute URL for crawler operators or content licensing."
      >
        <input id="contact-url" name="contactUrl" type="url" value={initialAiTraffic.contactUrl ?? ""} placeholder="https://example.com/contact" />
      </FormField>

      <FormField
        for="license-url"
        label="Content license URL"
        hint="Optional absolute URL describing reuse terms."
      >
        <input id="license-url" name="contentLicenseUrl" type="url" value={initialAiTraffic.contentLicenseUrl ?? ""} placeholder="https://example.com/license" />
      </FormField>

      <div class="actions">
        <button type="submit" class="btn primary">Save AI settings</button>
      </div>
      <p class="status" id="ai-traffic-status" role="status" />
    </form>

    <form class="panel" id="integrations-form">
      <ConfirmBar message="Google integrations render only on public pages after they are enabled with valid IDs. Consent and privacy requirements remain the site operator's responsibility." />

      <section class="subpanel" aria-labelledby="analytics-heading">
        <h2 id="analytics-heading">Google Analytics</h2>
        <div class="toggle-grid">
          <label>
            <input
              id="ga-enabled"
              type="checkbox"
              checked={initialIntegrations.googleAnalytics.enabled}
            />
            Enable Analytics
          </label>
        </div>
        <FormField
          for="ga-measurement-id"
          label="Measurement ID"
          hint="Use a GA4 Measurement ID such as G-XXXXXXXX."
        >
          <input
            id="ga-measurement-id"
            name="measurementId"
            type="text"
            value={initialIntegrations.googleAnalytics.measurementId ?? ""}
            placeholder="G-XXXXXXXX"
          />
        </FormField>
      </section>

      <section class="subpanel" aria-labelledby="adsense-heading">
        <h2 id="adsense-heading">Google AdSense</h2>
        <div class="toggle-grid">
          <label>
            <input
              id="adsense-enabled"
              type="checkbox"
              checked={initialIntegrations.googleAdSense.enabled}
            />
            Enable AdSense
          </label>
        </div>

        <FormField
          for="adsense-publisher-id"
          label="Publisher ID"
          hint="Use the AdSense Publisher ID such as ca-pub-0000000000000000."
        >
          <input
            id="adsense-publisher-id"
            name="publisherId"
            type="text"
            value={initialIntegrations.googleAdSense.publisherId ?? ""}
            placeholder="ca-pub-0000000000000000"
          />
        </FormField>

        <FormField
          for="adsense-mode"
          label="Ad mode"
          hint="Auto ads lets Google choose placements. Manual placements use the fixed slots below."
        >
          <select id="adsense-mode" name="mode">
            <option value="auto" selected={initialIntegrations.googleAdSense.mode === "auto"}>Auto ads</option>
            <option value="manual" selected={initialIntegrations.googleAdSense.mode === "manual"}>Manual placements</option>
          </select>
        </FormField>

        <div class="placements-table" aria-label="Manual AdSense placements">
          <div class="placements-row placements-head" aria-hidden="true">
            <span>Placement</span>
            <span>Enabled</span>
            <span>Slot ID</span>
          </div>
          {
            ADSENSE_PLACEMENT_KEYS.map((key) => (
              <div class="placements-row">
                <label for={`adsense-${key}-slot`}>{placementLabels[key]}</label>
                <input
                  id={`adsense-${key}-enabled`}
                  data-placement-enabled={key}
                  type="checkbox"
                  checked={initialIntegrations.googleAdSense.placements[key].enabled}
                  aria-label={`Enable ${placementLabels[key]}`}
                />
                <input
                  id={`adsense-${key}-slot`}
                  data-placement-slot={key}
                  type="text"
                  inputmode="numeric"
                  value={initialIntegrations.googleAdSense.placements[key].slotId ?? ""}
                  placeholder="1234567890"
                />
              </div>
            ))
          }
        </div>
      </section>

      <div class="actions">
        <button type="submit" class="btn primary">Save Google integrations</button>
      </div>
      <p class="status" id="integrations-status" role="status" />
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById("ai-traffic-form");
  const statusEl = document.getElementById("ai-traffic-status");
  const integrationsForm = document.getElementById("integrations-form");
  const integrationsStatusEl = document.getElementById("integrations-status");

  function setStatus(message: string, isError: boolean) {
    if (!(statusEl instanceof HTMLElement)) {
      return;
    }
    statusEl.textContent = message;
    statusEl.style.color = isError ? "#8b2942" : "#354139";
  }

  function setIntegrationsStatus(message: string, isError: boolean) {
    if (!(integrationsStatusEl instanceof HTMLElement)) {
      return;
    }
    integrationsStatusEl.textContent = message;
    integrationsStatusEl.style.color = isError ? "#8b2942" : "#354139";
  }

  function textareaValue(id: string): string {
    const el = document.getElementById(id);
    return el instanceof HTMLTextAreaElement ? el.value : "";
  }

  function inputValue(id: string): string | null {
    const el = document.getElementById(id);
    if (!(el instanceof HTMLInputElement)) {
      return null;
    }
    const value = el.value.trim();
    return value.length > 0 ? value : null;
  }

  function checked(id: string): boolean {
    const el = document.getElementById(id);
    return el instanceof HTMLInputElement ? el.checked : false;
  }

  function collectPlacements() {
    const placements: Record<string, { enabled: boolean; slotId: string | null }> = {};
    document.querySelectorAll("[data-placement-slot]").forEach((slotEl) => {
      if (!(slotEl instanceof HTMLInputElement)) {
        return;
      }
      const key = slotEl.dataset.placementSlot;
      if (!key) {
        return;
      }
      const enabledEl = document.querySelector(`[data-placement-enabled="${key}"]`);
      placements[key] = {
        enabled: enabledEl instanceof HTMLInputElement ? enabledEl.checked : false,
        slotId: slotEl.value.trim().length > 0 ? slotEl.value.trim() : null
      };
    });
    return placements;
  }

  function errorMessage(payload: unknown): string | null {
    if (!payload || typeof payload !== "object" || !("error" in payload)) {
      return null;
    }
    const error = (payload as { error: unknown }).error;
    return typeof error === "string" ? error : null;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const robotsPolicyEl = document.getElementById("robots-policy");
    const body = {
      siteDescription: textareaValue("ai-description"),
      robotsPolicy: robotsPolicyEl instanceof HTMLSelectElement ? robotsPolicyEl.value : "allow",
      aiUserAgents: textareaValue("ai-user-agents")
        .split("\n")
        .map((line) => line.trim())
        .filter(Boolean),
      llmsTxtEnabled: checked("llms-txt-enabled"),
      llmsFullTxtEnabled: checked("llms-full-enabled"),
      crawlersJsonEnabled: checked("crawlers-json-enabled"),
      contactUrl: inputValue("contact-url"),
      contentLicenseUrl: inputValue("license-url")
    };

    setStatus("Saving...", false);
    const res = await fetch("/api/admin/settings/ai-traffic", {
      method: "PATCH",
      headers: { "content-type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify(body)
    });
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) {
      setStatus(errorMessage(payload) ?? "Could not save AI settings.", true);
      return;
    }
    setStatus("AI settings saved.", false);
  });

  integrationsForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const modeEl = document.getElementById("adsense-mode");
    const body = {
      googleAnalytics: {
        enabled: checked("ga-enabled"),
        measurementId: inputValue("ga-measurement-id")
      },
      googleAdSense: {
        enabled: checked("adsense-enabled"),
        publisherId: inputValue("adsense-publisher-id"),
        mode: modeEl instanceof HTMLSelectElement ? modeEl.value : "auto",
        placements: collectPlacements()
      }
    };

    setIntegrationsStatus("Saving...", false);
    const res = await fetch("/api/admin/settings/integrations", {
      method: "PATCH",
      headers: { "content-type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify(body)
    });
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) {
      setIntegrationsStatus(
        errorMessage(payload) ?? "Could not save Google integrations.",
        true
      );
      return;
    }
    setIntegrationsStatus("Google integrations saved.", false);
  });
</script>

<style>
  .settings-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 22px;
    max-width: 880px;
  }

  .panel {
    display: grid;
    gap: 18px;
  }

  .subpanel {
    display: grid;
    gap: 16px;
    border-top: 1px solid #d8d0c2;
    padding-top: 18px;
  }

  .subpanel:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .subpanel h2 {
    margin: 0;
    font-size: 1.05rem;
  }

  input,
  select,
  textarea {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid #cfc7b8;
    padding: 10px 12px;
    background: #fbf9f4;
    color: #1f2523;
    font: inherit;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  .mono-input {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .toggle-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }

  .toggle-grid label {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid #d8d0c2;
    padding: 10px 12px;
    background: #fffdf8;
  }

  .toggle-grid input {
    width: auto;
  }

  .placements-table {
    display: grid;
    gap: 0;
    border: 1px solid #d8d0c2;
    background: #fffdf8;
  }

  .placements-row {
    display: grid;
    grid-template-columns: minmax(150px, 1fr) 96px minmax(150px, 1fr);
    gap: 12px;
    align-items: center;
    border-top: 1px solid #d8d0c2;
    padding: 10px 12px;
  }

  .placements-row:first-child {
    border-top: 0;
  }

  .placements-head {
    color: #6d746e;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .placements-row input[type="checkbox"] {
    width: auto;
  }

  .actions {
    display: flex;
    gap: 12px;
  }

  .btn {
    border: 1px solid #1f2523;
    padding: 10px 14px;
    background: #f5efe3;
    color: #1f2523;
    cursor: pointer;
    font: inherit;
  }

  .btn.primary {
    background: #2f6f4e;
    border-color: #2f6f4e;
    color: #fff;
  }

  .status {
    min-height: 1.4em;
    margin: 0;
  }

  @media (max-width: 640px) {
    .placements-head {
      display: none;
    }

    .placements-row {
      grid-template-columns: 1fr;
    }
  }
</style>
