---
import { env } from "cloudflare:workers";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminDashboardStats } from "../../lib/db/dashboard";

interface RuntimeEnv {
  CFBLOG_DB: D1Database;
}

const runtimeEnv = env as RuntimeEnv;
const stats = await getAdminDashboardStats(runtimeEnv.CFBLOG_DB);
const contentCounts = [
  { label: "Published", value: stats.publishedPosts },
  { label: "Drafts", value: stats.draftPosts },
  { label: "Scheduled", value: stats.scheduledPosts },
  { label: "Archived", value: stats.archivedPosts }
];
const systemCounts = [
  { label: "Categories", value: stats.categories, href: "/admin/categories" },
  { label: "Media assets", value: stats.mediaAssets, href: "/admin/media" },
  { label: "Redirects", value: stats.redirects, href: "/admin/redirects" }
];
---

<AdminLayout title="Dashboard">
  <section class="summary" aria-label="Publishing summary">
    <div>
      <p>Total posts</p>
      <strong>{stats.totalPosts}</strong>
    </div>
    {contentCounts.map((item) => (
      <div>
        <p>{item.label}</p>
        <strong>{item.value}</strong>
      </div>
    ))}
  </section>

  <section class="dashboard-grid">
    <div class="panel">
      <div class="panel-heading">
        <h2>Content</h2>
        <a href="/admin/posts">View posts</a>
      </div>
      <dl>
        {contentCounts.map((item) => (
          <>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </>
        ))}
      </dl>
    </div>

    <div class="panel">
      <div class="panel-heading">
        <h2>Site Structure</h2>
        <a href="/admin/categories">View categories</a>
      </div>
      <dl>
        {systemCounts.map((item) => (
          <>
            <dt>{item.label}</dt>
            <dd>
              <a href={item.href}>{item.value}</a>
            </dd>
          </>
        ))}
      </dl>
    </div>
  </section>
</AdminLayout>

<style>
  .summary {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid #d8d2c7;
    background: #d8d2c7;
  }

  .summary div {
    min-height: 108px;
    padding: 18px;
    background: #fbf9f4;
  }

  .summary p,
  .summary strong,
  h2,
  dl {
    margin: 0;
  }

  .summary p {
    color: #69736d;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .summary strong {
    display: block;
    margin-top: 18px;
    font-size: 2.4rem;
    line-height: 1;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 24px;
  }

  .panel {
    border: 1px solid #d8d2c7;
    background: #fbf9f4;
  }

  .panel-heading {
    border-bottom: 1px solid #d8d2c7;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  h2 {
    font-size: 1rem;
  }

  .panel-heading a {
    color: #2f6f4e;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .panel-heading a:hover {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  dl {
    display: grid;
    grid-template-columns: 1fr auto;
  }

  dt,
  dd {
    border-bottom: 1px solid #ece6dc;
    padding: 13px 18px;
  }

  dt:last-of-type,
  dd:last-of-type {
    border-bottom: 0;
  }

  dt {
    color: #56625a;
  }

  dd {
    font-weight: 800;
  }

  dd a {
    color: inherit;
    text-decoration: none;
  }

  dd a:hover {
    color: #2f6f4e;
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  @media (max-width: 960px) {
    .summary,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
