---
import { env } from "cloudflare:workers";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import FormField from "../../../../components/admin/FormField.astro";
import { getRedirectById } from "../../../../lib/db/redirects";
import { listCategories } from "../../../../lib/db/categories";
import { listAdminPosts } from "../../../../lib/db/posts";

interface RuntimeEnv {
  CFBLOG_DB: D1Database;
}

const runtimeEnv = env as RuntimeEnv;
const id = Astro.params.id;

if (!id) {
  return Astro.redirect("/admin/redirects", 302);
}

const redirect = await getRedirectById(runtimeEnv.CFBLOG_DB, id);

if (!redirect) {
  return Astro.redirect("/admin/redirects", 302);
}

const [posts, categories] = await Promise.all([
  listAdminPosts(runtimeEnv.CFBLOG_DB, { status: "published", limit: 500, offset: 0 }),
  listCategories(runtimeEnv.CFBLOG_DB)
]);

const pathTargets = [
  ...posts.map((p) => ({ kind: "post" as const, label: p.title, path: p.full_path })),
  ...categories.map((c) => ({ kind: "category" as const, label: c.name, path: c.full_path }))
].sort((a, b) => a.path.localeCompare(b.path));

const statusCodes = [301, 302, 307, 308];
---

<AdminLayout title="Edit redirect">
  <p class="intro">
    The from path cannot be changed. Update the destination, status code, or note.
  </p>

  <form class="panel" id="redirect-form" data-id={id}>
    <FormField for="from-path" label="From path">
      <input id="from-path" type="text" value={redirect.from_path} readonly />
    </FormField>

    <FormField for="to-path" label="To path">
      <input id="to-path" name="toPath" type="text" required value={redirect.to_path} />
    </FormField>

    <FormField for="target-picker" label="Browse targets">
      <select id="target-picker">
        <option value="">Select a post or category…</option>
        {pathTargets.map((t) => (
          <option value={t.path} selected={t.path === redirect.to_path}>
            [{t.kind}] {t.label} — {t.path}
          </option>
        ))}
      </select>
    </FormField>

    <FormField for="status-code" label="Status code">
      <select id="status-code" name="statusCode">
        {statusCodes.map((code) => (
          <option value={code} selected={redirect.status_code === code}>
            {code}
          </option>
        ))}
      </select>
    </FormField>

    <FormField for="note" label="Note">
      <input id="note" name="note" type="text" value={redirect.note ?? ""} />
    </FormField>

    <div class="actions">
      <button type="submit" class="btn primary">Save changes</button>
      <a class="btn" href="/admin/redirects">Back to list</a>
    </div>
    <p class="status" id="form-status" role="status"></p>
  </form>
</AdminLayout>

<script is:inline define:vars={{ redirectId: id }}>
  const form = document.getElementById("redirect-form");
  const targetPicker = document.getElementById("target-picker");
  const toPath = document.getElementById("to-path");
  const statusEl = document.getElementById("form-status");

  targetPicker?.addEventListener("change", () => {
    if (!(targetPicker instanceof HTMLSelectElement) || !(toPath instanceof HTMLInputElement)) return;
    if (targetPicker.value) {
      toPath.value = targetPicker.value;
    }
  });

  function errorMessage(payload) {
    if (!payload || typeof payload !== "object" || !("error" in payload)) {
      return null;
    }
    const error = payload.error;
    return typeof error === "string" ? error : null;
  }

  function setStatus(message, isError) {
    if (!(statusEl instanceof HTMLElement)) return;
    statusEl.textContent = message;
    statusEl.classList.toggle("error", isError);
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const toEl = document.getElementById("to-path");
    const statusCodeEl = document.getElementById("status-code");
    const noteEl = document.getElementById("note");

    const body = {
      toPath: toEl instanceof HTMLInputElement ? toEl.value : "",
      statusCode: statusCodeEl instanceof HTMLSelectElement ? Number(statusCodeEl.value) : 301,
      note: noteEl instanceof HTMLInputElement ? noteEl.value : ""
    };

    setStatus("Saving...", false);
    const res = await fetch(`/api/admin/redirects/${redirectId}`, {
      method: "PATCH",
      headers: { "content-type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify(body)
    });
    const payload = await res.json().catch(() => ({}));
    if (!res.ok) {
      setStatus(errorMessage(payload) || "Could not save redirect.", true);
      return;
    }
    const record =
      payload && typeof payload === "object" ? payload : {};
    const warning = typeof record.warning === "string" ? record.warning : "";
    setStatus(warning ? `Saved. ${warning}` : "Redirect updated.", false);
  });
</script>

<style>
  .intro {
    max-width: 52rem;
    margin: 0 0 20px;
    color: #536057;
    line-height: 1.55;
  }

  .panel {
    max-width: 640px;
    display: grid;
    gap: 18px;
  }

  input,
  select {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid #cfc7b8;
    padding: 10px 12px;
    background: #fbf9f4;
    font: inherit;
  }

  input[readonly] {
    background: #ece8df;
    color: #536057;
  }

  .actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn {
    display: inline-block;
    border: 1px solid #1f2523;
    padding: 10px 14px;
    background: #f5efe3;
    color: #1f2523;
    cursor: pointer;
    font: inherit;
    text-decoration: none;
  }

  .btn.primary {
    background: #2f6f4e;
    border-color: #2f6f4e;
    color: #fff;
  }

  .status {
    min-height: 1.4em;
    margin: 0;
  }

  .status.error {
    color: #9b2c2c;
  }
</style>
