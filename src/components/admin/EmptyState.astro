---
interface Props {
  title: string;
  detail: string;
  actionHref?: string;
  actionLabel?: string;
}

const { title, detail, actionHref, actionLabel } = Astro.props;
---

<section class="empty-state">
  <div>
    <h2>{title}</h2>
    <p>{detail}</p>
  </div>
  {actionHref && actionLabel && <a href={actionHref}>{actionLabel}</a>}
</section>

<style>
  .empty-state {
    border: 1px solid #d8d2c7;
    padding: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: #fbf9f4;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    font-size: 1.05rem;
  }

  p {
    margin-top: 8px;
    color: #5f6a62;
    line-height: 1.6;
  }

  a {
    flex: 0 0 auto;
    border: 1px solid #2f6f4e;
    padding: 9px 12px;
    color: #214d36;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  a:hover {
    background: #e8f0e8;
  }

  @media (max-width: 680px) {
    .empty-state {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
