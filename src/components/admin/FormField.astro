---
interface Props {
  label: string;
  for: string;
  hint?: string;
}

const { label, for: controlId, hint } = Astro.props;
---

<div class="field">
  <label for={controlId}>{label}</label>
  <slot />
  {hint && <p>{hint}</p>}
</div>

<style>
  .field {
    display: grid;
    gap: 7px;
  }

  label {
    color: #354139;
    font-size: 0.88rem;
    font-weight: 700;
  }

  p {
    margin: 0;
    color: #6d746e;
    font-size: 0.84rem;
    line-height: 1.5;
  }
</style>
