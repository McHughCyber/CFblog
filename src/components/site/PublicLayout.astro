---
import SiteFooter from "./SiteFooter.astro";
import SiteHeader from "./SiteHeader.astro";
import AdSenseSlot from "./AdSenseSlot.astro";
import type { IntegrationsSettings } from "../../lib/integrations/schema";
import type { ResolvedMenuNode } from "../../lib/menus/resolve";

interface Props {
  siteTitle: string;
  primaryNav: ResolvedMenuNode[];
  footerNav: ResolvedMenuNode[];
  logoPublicPath?: string | null;
  integrations?: IntegrationsSettings | null;
}

const {
  siteTitle,
  primaryNav,
  footerNav,
  logoPublicPath = null,
  integrations = null
} = Astro.props;
---

<div class="public-layout">
  <SiteHeader siteTitle={siteTitle} primaryNav={primaryNav} logoPublicPath={logoPublicPath} />
  <slot />
  {integrations && <AdSenseSlot integrations={integrations} placement="siteFooter" />}
  <SiteFooter footerNav={footerNav} siteTitle={siteTitle} />
</div>

<style>
  .public-layout {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
