{
  "name": "astro-cloudflare-blog-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrations:apply": "wrangler d1 migrations apply CFBLOG_DB --local",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@astrojs/cloudflare": "latest",
    "astro": "latest",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "latest",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "cloudflare": {
    "bindings": {
      "CFBLOG_DB": {
        "type": "d1",
        "description": "Canonical D1 database for posts, categories, menus, media metadata, redirects, settings, revisions, and schema versions."
      },
      "CFBLOG_MEDIA": {
        "type": "r2",
        "description": "R2 bucket for uploaded images and attachments."
      },
      "CFBLOG_CACHE": {
        "type": "kv",
        "description": "Optional low-risk cache namespace. Canonical content must stay in D1 and R2."
      }
    }
  }
}
